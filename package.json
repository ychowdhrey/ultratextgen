{
  "name": "ultratextgen",
  "version": "1.0.0",
  "private": true,
  "description": "Fast, clean Unicode text generator for social bios, captions, and usernames",
  "scripts": {
    "prebuild": "node scripts/update-sitemap.js",
    "build": "cp index.html _root.html",
    "sync-readme": "node scripts/sync-readme.js",
    "audit:css": "node scripts/audit-css.js",
