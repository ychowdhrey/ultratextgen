# Prevent Netlify automatic language-based redirects on the homepage.
# Without this rule, Netlify detects the browser Accept-Language header
# and redirects / to /fr/, /de/, etc. The 200! (forced rewrite) ensures
# the root always serves the English homepage; users switch language
# via the explicit language switcher in the footer.
/  /index.html  200!

/category/special-fonts/                    /category/strikethrough-text/ 301
/category/special-fonts/index.html          /category/strikethrough-text/ 301
/category/special-fonts/lines/              /category/strikethrough-text/ 301
/category/special-fonts/lines/index.html    /category/strikethrough-text/ 301
/category/special-fonts/effects/            /category/strikethrough-text/ 301
/category/special-fonts/effects/index.html  /category/strikethrough-text/ 301
/usecase/comment-fonts/                     /usecase/comment-font/   301
/usecase/comment-fonts/index.html           /usecase/comment-font/   301

# Language query-param → path-based (301 permanent)
/?lang=fr                                   /fr/    301
/?lang=de                                   /de/    301
/?lang=pt                                   /pt/    301
/?lang=es                                   /es/    301
/?lang=en                                   /       301
/?lang=id                                   /id/    301
/?lang=it                                   /it/    301
/?lang=nl                                   /nl/    301
/?lang=tr                                   /tr/    301
/?lang=pl                                   /pl/    301
/?lang=vi                                   /vi/    301





