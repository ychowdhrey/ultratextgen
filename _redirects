# The primary fix lives in functions/_middleware.js, which strips the
# Accept-Language header before calling ASSETS.fetch() so Cloudflare
# Pages' automatic i18n routing cannot redirect / to /fr/, /de/, etc.
# This rule acts as a safety net if the middleware is not deployed.
/  /index.html  200

