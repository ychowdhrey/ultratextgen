# Prevent browsers and edge caches from preserving a stale redirect
# from / to /fr/ (or any other locale).  The middleware now requests
# /_root.html (which has no locale variants) so i18n routing cannot
# activate.  These headers are a belt-and-suspenders fallback.
/
  Cache-Control: no-store
  Vary: Accept-Language
/index.html
  Cache-Control: no-store
  Vary: Accept-Language

# Short max-age with must-revalidate ensures browsers check for fresh
# copies without sacrificing performance for repeat visits.
/*.js
  Cache-Control: public, max-age=300, must-revalidate